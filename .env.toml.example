station_name = "example-station"
station_key = "replace-with-your-key"
server = "https://example.com/upload"

# Optional settings
sensor_type = "sensor_hat"
# record_frequency = 30
# storage_size = 2880
# data_path = "./data"

# Optional SN3003 serial sensor
# sn3003_port = "/dev/ttyS0"

# Optional display task
display_enabled = false
# display_frequency = 300

# Optional OV5647 camera task
camera_enabled = false
# camera_frequency = 1800

# Astral location for sunrise, sunset, moon phase and camera exposure
city = "Guangzhou"
country = "China"
timezone = "Asia/Harbin"
latitude = 23.109866
longitude = 113.2683
